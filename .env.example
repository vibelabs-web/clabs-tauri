# @TASK P4-T3 - macOS 코드 서명 및 공증 환경변수
# 이 파일을 .env.local로 복사하여 실제 값을 입력하세요
# ⚠️ .env.local은 절대 Git에 커밋하지 마세요!

# ===== macOS 코드 서명 =====

# Developer ID Application 인증서 이름
# 확인 방법: security find-identity -v -p codesigning
# 예시: "Developer ID Application: Your Name (TEAM_ID)"
CSC_NAME=""

# ===== macOS 공증 (Notarization) =====

# Apple ID (공증용)
APPLE_ID=""

# App-Specific Password (공증용)
# 생성 방법: https://appleid.apple.com/account/manage
# Security > App-Specific Passwords > Generate Password
APPLE_APP_SPECIFIC_PASSWORD=""

# Team ID
# 확인 방법: security find-certificate -c "Developer ID Application" -p | openssl x509 -noout -text | grep "OU="
# 또는 Apple Developer 사이트에서 확인
APPLE_TEAM_ID=""

# ===== Windows 코드 서명 (선택) =====

# Windows 인증서 파일 경로
# WIN_CSC_LINK=""

# Windows 인증서 비밀번호
# WIN_CSC_KEY_PASSWORD=""

# ===== 배포 설정 =====

# GitHub 저장소 (자동 업데이트용)
# GH_TOKEN=""
