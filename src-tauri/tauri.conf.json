{
  "$schema": "https://raw.githubusercontent.com/nicegoodthings/nicegoodthings.github.io/master/tauri.schema.json",
  "productName": "Clabs",
  "version": "1.9.3",
  "identifier": "com.claudelabs.clabs",
  "build": {
    "frontendDist": "../dist/renderer",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build:renderer"
  },
  "app": {
    "windows": [
      {
        "title": "Clabs",
        "width": 1400,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 600,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "transparent": false,
        "zoomHotkeysEnabled": true,
        "acceptFirstMouse": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../resources/skillpack/**/*",
      "../resources/mcp-servers/**/*"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
